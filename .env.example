# Copy this file to .env before running the app.
# Local-only defaults match docker-compose.yml; replace every production value.
DATABASE_URL=postgresql://deep:deep-local-only@localhost:5432/deep?sslmode=disable

# Generate a secret with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-at-least-32-random-characters

# Public origin used by Payload links and metadata. Do not include a trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Demo fixtures and generated assets are local/protected-staging only.
# This flag covers both demo content and assets.
DEMO_CONTENT_ENABLED=true

# Production indexing requires this explicit opt-in and DEMO_CONTENT_ENABLED=false.
SITE_INDEXING_ENABLED=false

# Optional: all three values are required together to create a local seed admin.
# Never commit a real password or reuse these credentials in a deployed environment.
# SEED_ADMIN_EMAIL=admin@example.test
# SEED_ADMIN_PASSWORD=replace-with-a-local-password
# SEED_ADMIN_NAME=Local Administrator
