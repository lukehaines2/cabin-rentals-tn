# Local development — copy to `.env` (gitignored) and replace secrets.
# Never commit a real `.env`. This repository is public.

# Local Postgres from docker-compose.yml
DATABASE_URL=postgresql://deep:deep-local-only@localhost:5432/deep?sslmode=disable

# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-at-least-32-random-characters

# Public origin. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Demo fixtures are for local / protected staging only.
DEMO_CONTENT_ENABLED=true

# Keep false until authorized launch content replaces demo fixtures.
SITE_INDEXING_ENABLED=false

# Optional local seed admin — all three required together.
# Never reuse these credentials on Netlify or any shared host.
# SEED_ADMIN_EMAIL=admin@example.test
# SEED_ADMIN_PASSWORD=replace-with-a-local-password
# SEED_ADMIN_NAME=Local Administrator
