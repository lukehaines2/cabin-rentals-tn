# Netlify environment template for a public GitHub repository.
#
# 1. Create a Netlify Database (injects NETLIFY_DB_URL), OR set DATABASE_URL.
# 2. Generate PAYLOAD_SECRET: openssl rand -base64 32
# 3. In Netlify → Site configuration → Environment variables → Import from
#    .env file, paste a filled copy of this file (never commit the filled copy).
# 4. Scopes: Builds + Functions/Runtime. Redeploy after importing.
#
# Do not put real secrets in git. Netlify stores them outside the repository.

# Prefer Netlify Database (NETLIFY_DB_URL). Set DATABASE_URL only when using an
# external Postgres provider instead.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Required. Unique per environment. Never reuse the local .env secret.
PAYLOAD_SECRET=replace-with-openssl-rand-base64-32-output

# Optional. When unset, the app uses Netlify's URL / DEPLOY_PRIME_URL.
# NEXT_PUBLIC_SERVER_URL=https://your-site-name.netlify.app

DEMO_CONTENT_ENABLED=true
SITE_INDEXING_ENABLED=false

# Optional Functions runtime pin for Node 24:
# AWS_LAMBDA_JS_RUNTIME=nodejs24.x
