{
  "name": "deep-cabin-discovery",
  "version": "0.1.0",
  "private": true,
  "description": "Guest-first cabin discovery and property-owner acquisition website.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.15.0 <27",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "node scripts/run-production-build.mjs",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke:guest-enquiry": "tsx --env-file=.env scripts/smoke-guest-enquiry.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload:types": "pnpm payload generate:types",
    "payload:importmap": "pnpm payload generate:importmap",
    "db:migrate:create": "pnpm payload migrate:create",
    "db:migrate": "pnpm payload migrate",
    "db:migrate:status": "pnpm payload migrate:status",
    "db:migrate:down": "pnpm payload migrate:down",
    "seed": "tsx --env-file=.env src/payload/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "date-fns": "^4.4.0",
    "graphql": "^16.8.1",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "payload": "3.86.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.1",
    "sharp": "0.35.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
